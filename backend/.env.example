# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Supabase
SUPABASE_URL=
SUPABASE_JWKS_URL=
SUPABASE_ANON_KEY=
# Service role key — used ONLY by GET /share/{token} via the security-definer RPC.
SUPABASE_SERVICE_ROLE_KEY=

# Share tokens (HMAC-signed, sha256 hash persisted)
SHARE_TOKEN_SECRET=
SHARE_LINK_BASE_URL=http://localhost:3000
SHARE_TOKEN_TTL_DAYS=30

# Catalog version stamped on generated layouts
CATALOG_VERSION=v1.mvp

# CORS allow-list (comma-separated or JSON array)
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
